def calculate_bmi(weight, height):
    """
    Рассчитывает индекс массы тела (ИМТ).

    Args:
        weight (float): Вес в килограммах
        height (float): Рост в метрах

    Returns:
        float: Значение ИМТ
    """
    return weight / (height ** 2)

def get_bmi_category(bmi):
    """
    Определяет категорию ИМТ на основе значения.

    Args:
        bmi (float): Значение индекса массы тела

    Returns:
        str: Категория ИМТ
    """
    if bmi < 18.5:
        return "Недостаточный вес"
    elif 18.5 <= bmi < 25:
        return "Нормальный вес"
    elif 25 <= bmi < 30:
        return "Избыточный вес"
    else:
        return "Ожирение"

def main():
    """
    Основная функция программы для расчета ИМТ.
    Обрабатывает ввод данных, вычисляет ИМТ и выводит результат.
    """
    weight, height = map(float, input("Введите ваш вес (кг) и рост (м) через пробел: ").split())
    bmi = calculate_bmi(weight, height)
    category = get_bmi_category(bmi)

    print(f"Ваш индекс массы тела: {bmi:.1f}")
    print(f"Категория: {category}")

if __name__ == "__main__":
    main()
