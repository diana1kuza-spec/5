import math

def calculate_distance(x1, y1, x2, y2):
    """
    Вычисляет расстояние между двумя точками на плоскости.

    Args:
    x1, y1 (float): Координаты первой точки
    x2, y2 (float): Координаты второй точки

    Returns:
    float: Расстояние между точками
    """
    return math.hypot(x2 - x1, y2 - y1)
    # или: return ((x2 - x1) ** 2 + (y2 - y1) ** 2) ** 0.5


def calculate_triangle_area(a, b, c):
    """
    Вычисляет площадь треугольника по трем сторонам (формула Герона).

    Args:
    a, b, c (float): Длины сторон треугольника

    Returns:
    float: Площадь треугольника
    """
    p = (a + b + c) / 2
    return (p * (p - a) * (p - b) * (p - c)) ** 0.5


def main():
    """
    Основная функция программы.
    Запрашивает координаты трех точек, вычисляет стороны треугольника и его площадь.
    """
    print("Введите координаты трех точек треугольника:")
    x1, y1 = map(float, input("Точка A (x y): ").split())
    x2, y2 = map(float, input("Точка B (x y): ").split())
    x3, y3 = map(float, input("Точка C (x y): ").split())

    # Вычисление длин сторон треугольника
    side_ab = calculate_distance(x1, y1, x2, y2)
    side_bc = calculate_distance(x2, y2, x3, y3)
    side_ca = calculate_distance(x3, y3, x1, y1)

    # Вычисление площади
    area = calculate_triangle_area(side_ab, side_bc, side_ca)

    # Вывод результатов
    print("\nРезультаты:")
    print(f"Длина стороны AB: {side_ab:.2f}")
    print(f"Длина стороны BC: {side_bc:.2f}")
    print(f"Длина стороны CA: {side_ca:.2f}")
    print(f"Площадь треугольника: {area:.2f}")


if __name__ == "__main__":
    main()
